# Project metadata
COMMIT_MESSAGE.txt

# Research / prototyping staging: prototypes, benches and design notes, some
# referencing confidential sibling research. Local only,
# graduates into tests/ and the tree once proven. Never shipped.
tests/research/

# Build directories and artifacts
/build/
/build-*/
*/build/
**/build/
/src/build/
cmake-build-*/
_*_build/

# CMake in-tree (avoid committing if someone configured in source)
/CMakeCache.txt
/CMakeFiles/
/cmake_install.cmake
/install_manifest.txt
/compile_commands.json

# Cargo build output (components/vector/, any future Rust crate). Cargo.lock stays
# tracked -- the MCP server is a binary crate, and binaries commit their lock
# file by convention; only the build output itself is ignored.
target/

# Binary outputs (if ever created at repo root)
/montauk
/montauk_analyze
/montauk_tests
/libmontauk_core.a

# Arch makepkg artifacts (keep source tree clean)
/pkg/
/*.pkg.tar.*
/*.src.tar.*
# makepkg's git+url source clones into ./src/<pkgname>/ when BUILDDIR
# isn't relocated. The PKGBUILD now auto-redirects BUILDDIR to /tmp,
# but this guards against any leak slipping past on a fresh checkout
# or edited PKGBUILD before the override lands.
/src/montauk/

# Local packaging workspace (created by helper scripts)
/packaging/_aur_local/

# Logs, cores, temp
*.log
*.out
core
*.core

# Editor/OS noise
.DS_Store
*.swp
*.swo
*.swp
*~
.idea/
.vscode/
.cache/
.clangd/

# Development test scripts
tests/show_colors.py

# Python bytecode
__pycache__/
*.pyc

# Kernel module build products -- kernel-version-specific, never committed
*.ko
components/kernel/*.mod*
components/kernel/*.o
components/kernel/.*.cmd
components/kernel/Module.symvers
components/kernel/modules.order
